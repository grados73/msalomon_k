#ifndef INC_BUTTON_H_
#define INC_BUTTON_H_

typedef enum
{
	IDLE = 0,
	DEBONCE,  //1
	PRESSED,  //2
	REPEAT    //3
} BUTTON_STATE;

typedef struct button_struct
{
	BUTTON_STATE	State;
	GPIO_TypeDef*	GpioPort;
	uint16_t		GpioPin;

}TButton;

void ButtonInitKey(TButton* Key, GPIO_TypeDef*	GpioPort, uint16_t	GpioPin);

void ButtonTask(TButton* Key);

#endif /* INC_BUTTON_H_ */
